{
  "name": "textbridge",
  "version": "1.0.0",
  "description": "Cross-platform text translation client with Windows-first system text capture and write-back.",
  "main": "dist-electron/electron/main.js",
  "scripts": {
    "build": "npm run build:renderer && npm run build:electron",
    "build:renderer": "vite build",
    "build:electron": "tsc -p tsconfig.electron.json",
    "helper:build": "dotnet build native/win32-helper/TextBridge.Win32Helper.csproj",
    "helper:test": "dotnet test native/win32-helper/TextBridge.Win32Helper.Tests/TextBridge.Win32Helper.Tests.csproj",
    "helper:publish": "dotnet publish native/win32-helper/TextBridge.Win32Helper.csproj -c Release -r win-x64 --self-contained false",
    "test": "vitest run",
    "test:minimax-live": "vitest run src/electron/services/providers/minimax-provider.integration.test.ts",
    "test:watch": "vitest",
    "typecheck": "npm run typecheck:renderer && npm run typecheck:electron",
    "typecheck:renderer": "tsc -p tsconfig.json --noEmit",
    "typecheck:electron": "tsc -p tsconfig.electron.json --noEmit",
    "dev": "npm run build:electron && concurrently -k -n renderer,electron-ts,electron -c green,blue,magenta \"npm:dev:renderer\" \"npm:watch:electron\" \"npm:dev:electron\"",
    "dev:renderer": "vite --host 127.0.0.1 --port 5173 --strictPort",
    "watch:electron": "tsc -p tsconfig.electron.json --watch --preserveWatchOutput",
    "dev:electron": "wait-on tcp:5173 dist-electron/electron/main.js && cross-env VITE_DEV_SERVER_URL=http://127.0.0.1:5173 nodemon --watch dist-electron --ext js --exec electron .",
    "start": "npm run build && electron .",
    "icons": "node scripts/generate-icons.js"
  },
  "keywords": [
    "electron",
    "desktop",
    "windows",
    "translation",
    "tray",
    "textbridge"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "react": "^19.2.0",
    "react-dom": "^19.2.0"
  },
  "devDependencies": {
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^24.8.1",
    "@types/react": "^19.2.2",
    "@types/react-dom": "^19.2.2",
    "@vitejs/plugin-react": "^5.0.4",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "electron": "^40.8.0",
    "jsdom": "^28.1.0",
    "nodemon": "^3.1.10",
    "sharp": "^0.34.5",
    "typescript": "^5.9.3",
    "vite": "^7.1.12",
    "vitest": "^4.0.18",
    "wait-on": "^8.0.5"
  }
}
